
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Admin - Peluquería</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body style="background-color: #212529;">
  <div class="m-5">
    <table class="table table-hover table-bordered text-center">
      <thead>
        <tr>
          <td class="color-text">Cliente</td>
          <td class="color-text">Turno</td>
          <td class="color-text">Servicio</td>
          <td class="color-text">estado</td>
          <td class="color-text">accion</td>
        </tr>
      </thead>
      <tbody>
        <% turnos.forEach(turnos => { %>
          <tr>
            <th class="color-text"><%= turnos.hora %></th>
            <th class="color-text"><%= turnos.cliente %></th>
            <th class="color-text"><%= turnos.servicio %></th>
            <td class="color-text">
              <% if (turnos.estado === "Pendiente") { %>
                <span class="badge bg-warning text-dark">Pendiente</span>
              <% } else { %>
                <span class="badge bg-success">Finalizado</span>
              <% } %>
            </td>
            <td>
              <button class="btn btn-success btn-sm">Atender</button>
              <button class="btn btn-danger btn-sm">Eliminar</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  
</body>
</html>